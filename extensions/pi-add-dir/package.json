{
  "name": "pi-add-dir",
  "version": "1.3.1",
  "description": "Add external directories to your pi session — loads their AGENTS.md, CLAUDE.md, and skills into context.",
  "keywords": [
    "pi-package",
    "pi",
    "coding-agent",
    "external-directory",
    "multi-project",
    "context"
  ],
  "scripts": {
    "lint": "eslint . && tsc --noEmit",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm run test"
  },
  "author": "itisbryan",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shelken/pi-extensions.git",
    "directory": "extensions/pi-add-dir"
  },
  "files": [
    "extensions",
    "README.md"
  ],
  "pi": {
    "extensions": [
      "./extensions"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": { "optional": true },
    "@earendil-works/pi-tui": { "optional": true },
    "typebox": { "optional": true }
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.78.0",
    "@earendil-works/pi-tui": "^0.78.0",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "typescript": "^6.0.3",
    "typebox": "^1.1.39",
    "vitest": "^4.1.2"
  }
}
