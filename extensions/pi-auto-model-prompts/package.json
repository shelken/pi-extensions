{
  "name": "@shelken/pi-auto-model-prompts",
  "version": "0.2.1",
  "description": "Inject model-specific system prompts into pi turns from local Markdown files.",
  "type": "module",
  "license": "MIT",
  "files": [
    "index.ts"
  ],
  "repository": {
