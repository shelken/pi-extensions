{
  "name": "@shelken/pi-extensions",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.13",
  "keywords": [
    "pi-package",
    "pi",
    "extensions"
  ],
  "workspaces": [
    "extensions/*"
  ],
  "scripts": {
    "check": "tsc --noEmit",
    "lint": "bun --filter pi-add-dir lint",
    "test": "bun --filter pi-co-authored-by test && bun --filter pi-add-dir test && bun --filter pi-auto-model-prompts test && bun --filter pi-debug-cache test && bun --filter pi-dynamic-models test",
    "verify": "bun run check && bun run lint && bun run test",
    "deps:update": "bun update --latest --recursive && bun run verify",
    "deps:update:interactive": "bun update --latest --interactive --recursive && bun run verify",
    "deps:update:dry": "bun update --latest --recursive --dry-run"
  },
  "pi": {
    "extensions": [
      "./extensions/pi-auto-model-prompts/index.ts",
      "./extensions/pi-debug-cache/index.ts",
      "./extensions/pi-dynamic-models/index.ts",
      "./extensions/pi-co-authored-by/extensions/co-authored-by.ts",
      "./extensions/pi-command-history/extensions/index.ts",
      "./extensions/pi-add-dir/extensions/pi-add-dir/index.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "0.78.0",
    "@earendil-works/pi-coding-agent": "0.78.0",
    "@earendil-works/pi-tui": "0.78.0",
    "@types/node": "25.9.1",
    "@typescript-eslint/eslint-plugin": "8.60.0",
    "@typescript-eslint/parser": "8.60.0",
    "eslint": "10.4.1",
    "typebox": "1.1.39",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  }
}
