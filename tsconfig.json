{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "skipLibCheck": true,
    "types": ["node"],
    "paths": {
      "@plannotator/pi-extension/plannotator-browser": [
        "./extensions/simple-plannotator/plannotator-browser.d.ts"
      ]
    },
    "resolveJsonModule": true
  },
  "include": ["extensions/**/*.ts"],
  "exclude": [
    "**/node_modules/**",
    "**/dist/**",
    "**/*.test.ts",
    "**/tests/**",
    "**/benchmarks/**"
  ]
}
